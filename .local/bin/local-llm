#!/usr/bin/env bash
# local-llm — pick a local LLM with fzf and serve it on :8080 for opencode.
#
# Each model launches via llama.cpp (llama-server) with its context window
# and sampling parameters tuned automatically. opencode's `local/selected`
# model talks to whatever is loaded here, so there is no per-model config to
# touch on the opencode side.
#
# To add or change a model: edit the registry() table below. Fields are
# pipe-separated:  label | hf-repo | extra launch flags
set -euo pipefail

HOST=127.0.0.1
PORT=8080
THREADS=12          # physical cores on this CPU (Ryzen AI 9 HX 370)
SELF=$(realpath "${BASH_SOURCE[0]}")

# ── model registry ─────────────────────────────────────────────────────────
registry() {
  cat <<'EOF'
Qwen3.6 35B A3B · Q8  — newest coding driver|unsloth/Qwen3.6-35B-A3B-GGUF:Q8_0|-c 131072 --temp 0.7 --top-p 0.8 --top-k 20 --min-p 0.0 --repeat-penalty 1.05
Qwen3-Coder 30B · Q8  — daily coding driver|unsloth/Qwen3-Coder-30B-A3B-Instruct-GGUF:Q8_0|-c 131072 --temp 0.7 --top-p 0.8 --top-k 20 --min-p 0.0 --repeat-penalty 1.05
Qwen3-Coder 30B · Q4  — fast / light coding|unsloth/Qwen3-Coder-30B-A3B-Instruct-GGUF:Q4_K_M|-c 131072 --temp 0.7 --top-p 0.8 --top-k 20 --min-p 0.0 --repeat-penalty 1.05
GLM-4.5-Air · Q4  — heavy / agentic coding|unsloth/GLM-4.5-Air-GGUF:Q4_K_M|-c 131072 --cache-type-k q8_0 --cache-type-v q8_0 --temp 0.6 --top-p 0.95 --top-k 40
gpt-oss 120B  — all-round reasoning + code|ggml-org/gpt-oss-120b-GGUF|-c 131072 --cache-type-k q8_0 --cache-type-v q8_0 --temp 1.0 --top-p 1.0 --top-k 0
Qwen3 30B Instruct · Q8  — general chat (not code)|unsloth/Qwen3-30B-A3B-Instruct-2507-GGUF:Q8_0|-c 131072 --temp 0.7 --top-p 0.8 --top-k 20 --min-p 0.0
EOF
}

# ── strengths shown in the fzf preview pane ────────────────────────────────
preview() {
  case "${1:-}" in
  "Qwen3.6 35B A3B · Q8"*)
    cat <<'EOF'

  Qwen3.6 35B A3B  ·  Q8_0

  NEWEST CODING DRIVER

  MoE: 35B total params, ~3B active per token —
  a newer generation than Qwen3-Coder 30B, so it
  stays just as fast while loaded at full Q8.

   • Latest Qwen coding-capable release
   • Strong at agentic / tool-use workflows (opencode)
   • Reliable native function calling

  RAM    ~38 GB
  Speed  ~15-25 tok/s   (estimate for this iGPU)
  Ctx    128K
EOF
    ;;
  "Qwen3-Coder 30B · Q8"*)
    cat <<'EOF'

  Qwen3-Coder 30B A3B  ·  Q8_0

  THE DAILY CODING DRIVER

  MoE: 30B total params, only ~3B active per token —
  so it stays fast even at full Q8 precision.

   • Best open coding model in its size class
   • Strong at agentic / tool-use workflows (opencode)
   • Reliable native function calling

  RAM    ~33 GB
  Speed  ~15-25 tok/s   (estimate for this iGPU)
  Ctx    128K
EOF
    ;;
  "Qwen3-Coder 30B · Q4"*)
    cat <<'EOF'

  Qwen3-Coder 30B A3B  ·  Q4_K_M

  SAME MODEL, LIGHTER

   • ~half the RAM of Q8, noticeably snappier
   • Minor quality dip vs Q8
   • Good for fast iteration, or to leave RAM free
     for big builds / browsers

  RAM    ~18 GB
  Speed  ~25-35 tok/s   (estimate for this iGPU)
  Ctx    128K
EOF
    ;;
  "GLM-4.5-Air"*)
    cat <<'EOF'

  GLM-4.5-Air  ·  Q4_K_M

  THE HEAVYWEIGHT — for hard problems

  MoE: 106B total params, ~12B active per token.
  Clearly smarter on hard, multi-step and agentic
  coding tasks than Qwen3-Coder.

   • Reach for it when Qwen3-Coder isn't good enough
   • KV cache is quantized (q8_0) so it fits in RAM

  RAM    ~65 GB
  Speed  ~5-8 tok/s     (estimate for this iGPU)
  Ctx    128K
EOF
    ;;
  "gpt-oss 120B"*)
    cat <<'EOF'

  gpt-oss 120B  ·  MXFP4 (native)

  THE ALL-ROUNDER

  OpenAI's open MoE: ~120B total / ~5B active.
  Strong general reasoning plus solid coding, with
  adjustable built-in reasoning effort.

   • Best when a task mixes code with research,
     analysis or planning
   • KV cache quantized (q8_0) so it fits in RAM

  RAM    ~63 GB
  Speed  ~10-15 tok/s   (estimate for this iGPU)
  Ctx    128K
EOF
    ;;
  "Qwen3 30B Instruct"*)
    cat <<'EOF'

  Qwen3 30B A3B Instruct (2507)  ·  Q8_0

  GENERAL ASSISTANT — not for code

  Same fast MoE architecture as Qwen3-Coder
  (~3B active) but tuned for chat, writing,
  Q&A and summarizing.

   • Use it for everything that isn't coding
   • Snappy, modest RAM

  RAM    ~33 GB
  Speed  ~15-25 tok/s   (estimate for this iGPU)
  Ctx    128K
EOF
    ;;
  *)
    echo "  (no description)"
    ;;
  esac
}

usage() {
  cat <<EOF
local-llm — pick a local LLM and serve it on :$PORT for opencode

  usage:  local-llm        open the fzf picker
          local-llm -h     show this help

  Models run via llama.cpp with per-model context and sampling tuned
  automatically. Any running model is replaced when you pick a new one.
  opencode is already wired to whatever is loaded (model: local/selected).

  Add or edit models in the registry() table inside this script:
    $SELF
EOF
}

# ── dispatch ───────────────────────────────────────────────────────────────
case "${1:-}" in
  --preview) preview "${2:-}"; exit 0 ;;
  -h|--help) usage; exit 0 ;;
  "") ;;
  *) echo "unknown option: $1" >&2; usage >&2; exit 1 ;;
esac

command -v fzf          >/dev/null || { echo "error: fzf not installed"        >&2; exit 1; }
command -v llama-server >/dev/null || { echo "error: llama-server not installed">&2; exit 1; }

choice=$(registry | cut -d'|' -f1 \
  | fzf --prompt='serve ▶ ' \
        --height=95% --layout=reverse --border=rounded \
        --header='↑↓ choose a model · Enter to serve · Esc to cancel' \
        --preview="$SELF --preview {}" \
        --preview-window='right,60%,wrap') \
  || { echo "cancelled."; exit 0; }

row=$(registry | awk -F'|' -v l="$choice" '$1==l {print; exit}')
repo=$(cut -d'|' -f2 <<<"$row")
flags=$(cut -d'|' -f3 <<<"$row")

# replace any model already serving on this port
if pids=$(pgrep -f "llama-server.*--port $PORT" 2>/dev/null); then
  echo "→ stopping current server (pid: $(echo "$pids" | tr '\n' ' '))"
  # shellcheck disable=SC2086
  kill $pids 2>/dev/null || true
  sleep 1
fi

echo "→ serving: $choice"
echo "→ model:   $repo"
echo "→ url:     http://$HOST:$PORT   (Ctrl+C to stop)"
echo

# word-splitting of $flags is intentional
# shellcheck disable=SC2086
exec llama-server -hf "$repo" \
  -ngl 99 -fa on -t "$THREADS" \
  --host "$HOST" --port "$PORT" --jinja \
  $flags
